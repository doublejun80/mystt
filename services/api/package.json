{
  "name": "@mystt/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/app.ts --format esm --dts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.914.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^10.0.0",
    "@mystt/audio-core": "workspace:*",
    "@mystt/notes-schema": "workspace:*",
    "@mystt/session-queue": "workspace:*",
    "@mystt/soniox-client": "workspace:*",
    "@mystt/transcript-normalizer": "workspace:*",
    "@soniox/node": "^1.1.2",
    "docx": "^9.5.1",
    "fastify": "^5.1.0",
    "nodemailer": "^6.10.0",
    "openai": "^6.33.0",
    "pg": "^8.16.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.6"
  }
}
