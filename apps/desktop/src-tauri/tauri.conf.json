{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mystt Desktop",
  "version": "0.1.0",
  "identifier": "digital.doublejun.mystt.desktop",
  "build": {
    "beforeDevCommand": "node ./scripts/ensure-dev-server.mjs",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "mystt Desktop",
        "width": 1280,
        "height": 860,
        "minWidth": 390,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
