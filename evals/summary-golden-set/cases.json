{
  "version": 1,
  "cases": [
    {
      "id": "meeting-launch-sync",
      "mode": "meeting",
      "mustContain": ["decision", "actionItems", "speakerHighlights"],
      "mustNotHallucinate": ["owner", "dueDate"]
    },
    {
      "id": "speech-townhall",
      "mode": "speech",
      "mustContain": ["keyMessages", "quotableLines", "sectionSummaries"],
      "mustNotHallucinate": ["audienceQna"]
    },
    {
      "id": "interview-candidate",
      "mode": "interview",
      "mustContain": ["questionAnswerPairs", "keyInsights", "followUpQuestions"],
      "mustNotHallucinate": ["sensitiveStatements"]
    }
  ]
}

